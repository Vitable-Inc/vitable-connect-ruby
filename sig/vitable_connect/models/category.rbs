module VitableConnect
  module Models
    type category = :Medical | :Dental | :Vision | :Hospital

    module Category
      extend VitableConnect::Internal::Type::Enum

      MEDICAL: :Medical
      DENTAL: :Dental
      VISION: :Vision
      HOSPITAL: :Hospital

      def self?.values: -> ::Array[VitableConnect::Models::category]
    end
  end
end
