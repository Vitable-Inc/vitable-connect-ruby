module VitableConnect
  module Models
    type employer_update_params =
      {
        active: bool?,
        address: VitableConnect::EmployerUpdateParams::Address?,
        legal_name: String?,
        name: String?
      }
      & VitableConnect::Internal::Type::request_parameters

    class EmployerUpdateParams < VitableConnect::Internal::Type::BaseModel
      extend VitableConnect::Internal::Type::RequestParameters::Converter
      include VitableConnect::Internal::Type::RequestParameters

      attr_accessor active: bool?

      attr_accessor address: VitableConnect::EmployerUpdateParams::Address?

      attr_accessor legal_name: String?

      attr_accessor name: String?

      def initialize: (
        ?active: bool?,
        ?address: VitableConnect::EmployerUpdateParams::Address?,
        ?legal_name: String?,
        ?name: String?,
        ?request_options: VitableConnect::request_opts
      ) -> void

      def to_hash: -> {
        active: bool?,
        address: VitableConnect::EmployerUpdateParams::Address?,
        legal_name: String?,
        name: String?,
        request_options: VitableConnect::RequestOptions
      }

      type address =
        {
          :address_line_1 => String,
          city: String,
          state: String,
          zipcode: String,
          :address_line_2 => String?
        }

      class Address < VitableConnect::Internal::Type::BaseModel
        attr_accessor address_line_1: String

        attr_accessor city: String

        attr_accessor state: String

        attr_accessor zipcode: String

        attr_accessor address_line_2: String?

        def initialize: (
          address_line_1: String,
          city: String,
          state: String,
          zipcode: String,
          ?address_line_2: String?
        ) -> void

        def to_hash: -> {
          :address_line_1 => String,
          city: String,
          state: String,
          zipcode: String,
          :address_line_2 => String?
        }
      end
    end
  end
end
