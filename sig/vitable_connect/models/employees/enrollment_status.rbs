module VitableConnect
  module Models
    module Employees
      type enrollment_status = :pending | :enrolled | :waived | :inactive

      module EnrollmentStatus
        extend VitableConnect::Internal::Type::Enum

        PENDING: :pending
        ENROLLED: :enrolled
        WAIVED: :waived
        INACTIVE: :inactive

        def self?.values: -> ::Array[VitableConnect::Models::Employees::enrollment_status]
      end
    end
  end
end
