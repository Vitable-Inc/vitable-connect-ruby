module VitableConnect
  module Models
    module Members
      type qualifying_life_event_status = :pending | :approved | :denied

      module QualifyingLifeEventStatus
        extend VitableConnect::Internal::Type::Enum

        PENDING: :pending
        APPROVED: :approved
        DENIED: :denied

        def self?.values: -> ::Array[VitableConnect::Models::Members::qualifying_life_event_status]
      end
    end
  end
end
