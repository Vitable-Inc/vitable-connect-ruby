module VitableConnect
  module Models
    type enrollment =
      {
        id: String,
        answered_at: Time?,
        benefit: VitableConnect::Enrollment::Benefit,
        coverage_end: Date?,
        coverage_start: Date,
        created_at: Time,
        employee_deduction_in_cents: Integer?,
        employee_id: String,
        employer_contribution_in_cents: Integer?,
        employer_id: String,
        status: VitableConnect::Models::enrollment_status,
        terminated_at: Time?,
        updated_at: Time
      }

    class Enrollment < VitableConnect::Internal::Type::BaseModel
      attr_accessor id: String

      attr_accessor answered_at: Time?

      attr_accessor benefit: VitableConnect::Enrollment::Benefit

      attr_accessor coverage_end: Date?

      attr_accessor coverage_start: Date

      attr_accessor created_at: Time

      attr_accessor employee_deduction_in_cents: Integer?

      attr_accessor employee_id: String

      attr_accessor employer_contribution_in_cents: Integer?

      attr_accessor employer_id: String

      attr_accessor status: VitableConnect::Models::enrollment_status

      attr_accessor terminated_at: Time?

      attr_accessor updated_at: Time

      def initialize: (
        id: String,
        answered_at: Time?,
        benefit: VitableConnect::Enrollment::Benefit,
        coverage_end: Date?,
        coverage_start: Date,
        created_at: Time,
        employee_deduction_in_cents: Integer?,
        employee_id: String,
        employer_contribution_in_cents: Integer?,
        employer_id: String,
        status: VitableConnect::Models::enrollment_status,
        terminated_at: Time?,
        updated_at: Time
      ) -> void

      def to_hash: -> {
        id: String,
        answered_at: Time?,
        benefit: VitableConnect::Enrollment::Benefit,
        coverage_end: Date?,
        coverage_start: Date,
        created_at: Time,
        employee_deduction_in_cents: Integer?,
        employee_id: String,
        employer_contribution_in_cents: Integer?,
        employer_id: String,
        status: VitableConnect::Models::enrollment_status,
        terminated_at: Time?,
        updated_at: Time
      }

      type benefit =
        {
          id: String,
          category: VitableConnect::Models::category,
          name: String,
          product_code: VitableConnect::Models::product_code
        }

      class Benefit < VitableConnect::Internal::Type::BaseModel
        attr_accessor id: String

        attr_accessor category: VitableConnect::Models::category

        attr_accessor name: String

        attr_accessor product_code: VitableConnect::Models::product_code

        def initialize: (
          id: String,
          category: VitableConnect::Models::category,
          name: String,
          product_code: VitableConnect::Models::product_code
        ) -> void

        def to_hash: -> {
          id: String,
          category: VitableConnect::Models::category,
          name: String,
          product_code: VitableConnect::Models::product_code
        }
      end
    end
  end
end
